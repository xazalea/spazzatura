{
  "name": "spazzatura",
  "version": "0.2.0",
  "description": "Unified AI coding tool — free by default, surpasses Claude Code",
  "homepage": "https://github.com/spazzatura/spazzatura",
  "keywords": ["ai", "cli", "llm", "coding-assistant", "agent", "free", "open-source"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "spazzatura": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@spazzatura/agent": "workspace:*",
    "@spazzatura/core": "workspace:*",
    "@spazzatura/effects": "workspace:*",
    "@spazzatura/idle": "workspace:*",
    "@spazzatura/provider": "workspace:*",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "highlight.js": "^11.9.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^9.2.0",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0",
    "ora": "^8.0.0",
    "playwright": "^1.48.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
