{
  "name": "spazzatura",
  "version": "0.2.0",
  "description": "Fully Free CLI tool for u.",
  "private": false,
  "type": "module",
  "keywords": [
    "cli",
    "llm",
    "ai",
    "coding",
    "agent",
    "skills",
    "specifications",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "spazzatura": "./packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist"
  ],
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "lint": "eslint packages/*/src --ext .ts",
    "test": "pnpm -r run test",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm run build",
    "benchmark": "pnpm --filter @spazzatura/benchmark run benchmark",
    "publish:npm": "npm publish --access public"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "typescript": "^5.3.3",
    "tsup": "^8.0.1",
    "vitest": "^1.2.0"
  }
}
